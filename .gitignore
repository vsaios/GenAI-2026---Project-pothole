# Ignore all .env files (secrets, API keys)
.env
.env.local
*.env
**/.env
!.env.example
node_modules
.next
dist

# Backend SQLite DB and uploads
pothole-ai-system/backend/data/

# Ignore Python cache and build files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environments
.venv/
venv/

# Ignore model and binary files
*.tflite
*.h5
*.pt
*.bin
*.exe
*.dll
*.so

# Ignore log and temp files
*.log
*.tmp

# Ignore hardware models
pothole-ai-system/hardware/models/
 
# Ignore frontend dependencies
pothole-ai-system/frontend/node_modules/
# Ignore build outputs
pothole-ai-system/frontend/dist/
pothole-ai-system/backend/app/__pycache__/
pothole-ai-system/ai/Moorcheh/__pycache__/
.DS_Store
.vscode/
